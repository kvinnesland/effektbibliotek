generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  email       String   @id
  name        String
  isAdmin     Boolean  @default(false)
  createdAt   DateTime @default(now())
  lastLoginAt DateTime?

  cases       Case[]   @relation("CaseOwner")
  createdCases Case[]  @relation("CaseCreator")
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
}

model Case {
  id    String @id @default(cuid())

  customerName          String
  title                 String
  summary               String
  customerFacingSummary String?

  lifecycleStatus  CaseLifecycleStatus @default(started)
  usageLevel       CaseUsageLevel      @default(not_cleared)

  industry    Industry?
  caseTypes   CaseType[]
  channels    Channel[]
  effectTypes EffectType[]
  tags        String[]

  problem     String?
  solution    String?
  resultSummary String?
  learning    String?
  relevance   String?
  pitchText   String?
  internalNotes String?

  effectMetric      String?
  beforeValue       String?
  afterValue        String?
  resultValue       String?
  measurementPeriod String?
  dataSource        String?
  evidenceLevel     EvidenceLevel?

  usageApprovalStatus UsageApprovalStatus @default(not_requested)
  usageApprovalToken  String?             @unique @default(cuid())

  ndaRestricted          Boolean @default(false)
  anonymizedUseOnly      Boolean @default(false)
  competitionUseAllowed  Boolean @default(false)

  ownerEmail   String
  owner        User   @relation("CaseOwner", fields: [ownerEmail], references: [email])
  createdByEmail String
  createdBy    User   @relation("CaseCreator", fields: [createdByEmail], references: [email])

  usageApprovals UsageApproval[]
  links          CaseLink[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedByEmail String?
}

model UsageApproval {
  id     String @id @default(cuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id])

  submittedAt          DateTime @default(now())
  submittedByName      String
  submittedByEmail     String
  submittedByRole      String?

  ndaRestricted             Boolean @default(false)
  internalUseAllowed        Boolean @default(false)
  anonymizedUseOnly         Boolean @default(false)
  presentationUseAllowed    Boolean @default(false)
  competitionUseAllowed     Boolean @default(false)

  note      String?
  lockedAt  DateTime @default(now())

  confirmationEmailSentAt DateTime?
  copiedToBasEmail        String?

  @@index([caseId])
}

model CaseLink {
  id     String @id @default(cuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id])

  title       String
  url         String
  type        CaseLinkType?
  description String?

  createdAt      DateTime @default(now())
  createdByEmail String

  @@index([caseId])
}

enum CaseLifecycleStatus {
  started
  ongoing
  completed
}

enum CaseUsageLevel {
  not_cleared
  internal_only
  presentation_allowed
}

enum UsageApprovalStatus {
  not_requested
  open
  submitted_locked
}

enum Industry {
  retail
  bank_finance
  insurance
  telecom
  energy
  public_sector
  health
  travel
  b2b
  other
}

enum CaseType {
  sales_conversion
  customer_journey
  automation
  loyalty
  lead_generation
  winback
  onboarding
  notification
  document_distribution
  customer_insight
  concept_pilot
  cost_reduction
  antichurn
  other
}

enum Channel {
  sms
  rcs
  email
  push
  web
  landing_page
  chatbot
  api
  paid_media
  post_letter
  digipost
  physical_store
  multi_channel
  other
}

enum EffectType {
  increased_sales
  increased_conversion
  reduced_cost
  increased_response
  increased_traffic
  better_customer_experience
  time_saved
  higher_delivery_rate
  documented_receipt
  reduced_manual_work
  documented_learning
  qualitative_effect
}

enum EvidenceLevel {
  documented
  estimated
  qualitative
  not_measured
}

enum CaseLinkType {
  presentation
  report
  dashboard
  figma
  campaign
  website
  documentation
  other
}
